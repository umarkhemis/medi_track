# Django
DJANGO_ENV=dev
SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (set USE_SQLITE=False to use PostgreSQL)
USE_SQLITE=True
DB_NAME=meditrack
DB_USER=meditrack_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Africa's Talking SMS (optional — used if AT_API_KEY is set)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SMS_SENDER_ID=MediTrack
AT_INBOUND_SECRET=your-inbound-secret
AT_DELIVERY_SECRET=your-delivery-secret

# Twilio SMS/WhatsApp (optional — fill in to switch from simulation to real SMS)
# When these are set, real SMS/WhatsApp messages are sent immediately.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Phone number default country (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY_CODE=UG

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS (production only)
CORS_ALLOWED_ORIGINS=http://localhost:3000
