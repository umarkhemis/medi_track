# Django
DJANGO_ENV=dev
SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (set USE_SQLITE=False to use PostgreSQL)
USE_SQLITE=True
DB_NAME=meditrack
DB_USER=meditrack_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Africa's Talking SMS
AT_USERNAME=sandbox
AT_API_KEY=your_africa_talking_api
AT_SMS_SENDER_ID=MediTrack
AT_INBOUND_SECRET=your-inbound-secret
AT_DELIVERY_SECRET=your-delivery-secret

# Phone number default country (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY_CODE=KE

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS (production only)
CORS_ALLOWED_ORIGINS=http://localhost:3000
